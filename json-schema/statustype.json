{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/la-poste/main/json-schema/statustype.json",
  "title": "StatusType",
  "type": "object",
  "properties": {
    "reasonPhrase": {
      "type": "string"
    },
    "family": {
      "type": "string",
      "enum": [
        "INFORMATIONAL",
        "SUCCESSFUL",
        "REDIRECTION",
        "CLIENT_ERROR",
        "SERVER_ERROR",
        "OTHER"
      ]
    },
    "statusCode": {
      "type": "integer",
      "format": "int32"
    }
  }
}