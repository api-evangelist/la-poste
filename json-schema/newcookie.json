{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/la-poste/main/json-schema/newcookie.json",
  "title": "NewCookie",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "format": "int32"
    },
    "path": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "maxAge": {
      "type": "integer",
      "format": "int32"
    },
    "expiry": {
      "type": "string",
      "format": "date-time"
    },
    "secure": {
      "type": "boolean"
    },
    "httpOnly": {
      "type": "boolean"
    },
    "sameSite": {
      "type": "string",
      "enum": [
        "NONE",
        "LAX",
        "STRICT"
      ]
    }
  }
}